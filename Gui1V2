local function MakeDraggable(DraggableObject, TargetObject) TargetObject = TargetObject or DraggableObject local dragging, dragInput, dragStart, startPos

DraggableObject.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = TargetObject.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

DraggableObject.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        TargetObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

end

function Library:CreateWindow(WindowName, Config) Config = Config or {} local ToggleConfig = Config.ToggleConfig or {} local isFirstTab = true local ThemeConfig = Config.ThemeColor or Color3.fromRGB(115, 196, 237) local isRainbow = false local CurrentThemeColor = Color3.fromRGB(115, 196, 237)

if type(ThemeConfig) == "string" and string.lower(ThemeConfig) == "rainbow" then
    isRainbow = true
elseif typeof(ThemeConfig) == "Color3" then
    CurrentThemeColor = ThemeConfig
end

local ThemedElements = {}
local function ApplyTheme(instance, property)
    instance[property] = CurrentThemeColor
    if isRainbow then
        table.insert(ThemedElements, {
            UpdateFunc = function(color)
                if instance and instance.Parent then
                    instance[property] = color
                end
            end
        })
    end
end

local TextColorConfig = Config.TextColor or Color3.fromRGB(255, 255, 255)
local isTextRainbow = false
local CurrentTextColor = Color3.fromRGB(255, 255, 255)

if type(TextColorConfig) == "string" and string.lower(TextColorConfig) == "rainbow" then
    isTextRainbow = true
elseif typeof(TextColorConfig) == "Color3" then
    CurrentTextColor = TextColorConfig
end

local TextElements = {}
local function ApplyTextColor(instance, property)
    property = property or "TextColor3"
    instance[property] = CurrentTextColor
    if isTextRainbow then
        table.insert(TextElements, {
            UpdateFunc = function(color)
                if instance and instance.Parent then
                    instance[property] = color
                end
            end
        })
    end
end

if isRainbow or isTextRainbow then
    RunService.RenderStepped:Connect(function()
        local rColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        if isRainbow then
            CurrentThemeColor = rColor
            for _, data in ipairs(ThemedElements) do
                data.UpdateFunc(CurrentThemeColor)
            end
        end
        if isTextRainbow then
            CurrentTextColor = rColor
            for _, data in ipairs(TextElements) do
                data.UpdateFunc(CurrentTextColor)
            end
        end
    end)
end

