-- [[ โหลด Library ]]
local Library = loadstring(game:HttpGet("https://github.com/Generallua/Gui/raw/refs/heads/main/Gui1V2"))()

-- [[ สร้างหน้าต่างหลัก ]]
local Window = Library:CreateWindow("PM - Premium Hub", {
    Logo = "rbxassetid://98985755793415",
    ThemeColor = "rainbow",
    ImageTransparency = 0.4,
    ToggleConfig = {
        Text = "Open/Close (P)"
    }
})

-- [[ สร้างหมวดหมู่ (Categories) ]]
local Main = Window:CreateCategory("Main", "home")
local Player = Window:CreateCategory("Player", "user")
local Test = Window:CreateCategory("Stress Test", "layers")

-- [[ หมวดหมู่ Main ]]
Main:CreateLabel("Gui1V2 - Developer Mode")

Main:CreateButton("Print Hello", function()
    print("Hello World!")
end, "play")

Main:CreateToggle("Auto Farm (Demo)", false, function(v)
    print("Auto Farm is now:", v)
end, "power")

Main:CreateDropdown("Select Team", {"Red", "Blue", "Green", "Yellow"}, function(v)
    print("Selected Team:", v)
end, "list")

Main:CreateTextbox("Chat Message", "Type here...", function(text)
    print("User typed:", text)
end, "message-square")

-- [[ หมวดหมู่ Player ]]
Player:CreateSlider("WalkSpeed", 16, 200, 16, function(v)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
end, "gauge")

Player:CreateSlider("Jump Power", 50, 200, 50, function(v)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
end, "zap")

Player:CreateButton("Manual Jump", function()
    game.Players.LocalPlayer.Character.Humanoid.Jump = true
end, "arrow-up")

-- เพิ่มฟังก์ชัน Infinite Jump
local infJumpEnabled = false
Player:CreateToggle("Infinite Jump", false, function(v)
    infJumpEnabled = v
end, "wind")

game:GetService("UserInputService").JumpRequest:Connect(function()
    if infJumpEnabled then
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- [[ หมวดหมู่ Stress Test ]]
-- สร้างปุ่มทดสอบ 25 ปุ่ม
for i = 1, 25 do
    Test:CreateButton("Test Button "..i, function()
        print("Pressed Button Number: "..i)
    end, "box")
end

-- สร้างหมวดหมู่ทดสอบเพิ่มอีก 5 หมวด (ลดลงจาก 25 เพื่อความลื่นไหล)
for i = 1, 5 do
    Window:CreateCategory("Stress "..i, "box")
end

print("GUI Loaded Successfully!")
