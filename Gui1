                    if instance and instance.Parent then
                        instance[property] = color
                    end
                end
            })
        end
    end

    if isRainbow then
        RunService.RenderStepped:Connect(function()
            CurrentThemeColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)
