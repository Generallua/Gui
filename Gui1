            local function UpdateToggle(animate)
                local goalPos = CurrentState and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                local goalColor = CurrentState and CurrentThemeColor or Color3.fromRGB(200, 200, 200)
                if animate then
                    TweenService:Create(ToggleKnob, TweenInfo.new(0.2), {Position = goalPos, BackgroundColor3 = goalColor}):Play()
                else
                    ToggleKnob.Position = goalPos
                    ToggleKnob.BackgroundColor3 = goalColor
                end
                if Callback then Callback(CurrentState) end
            end

            -- อัปเดตสี Toggle อัตโนมัติเมื่อเป็น Rainbow
            if isRainbow then
                table.insert(ThemedElements, {
                    UpdateFunc = function(color)
                        if ToggleKnob and ToggleKnob.Parent and CurrentState then
                            ToggleKnob.BackgroundColor3 = color
                        end
                    end
                })
            end

            ToggleContainer.MouseButton1Click:Connect(function()
                CurrentState = not CurrentState
                UpdateToggle(true)
            end)
            UpdateToggle(false)
        end

        function CategoryElements:CreateSlider(SliderText, Min, Max, Default, Callback)
            local CurrentValue = Default or Min
            local SliderContainer = Instance.new("Frame")
