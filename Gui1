local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

function Library:CreateWindow(WindowName)
    local WindowElements = {}
    local isFirstTab = true
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "LMG2L_UI"
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- ปุ่มสำหรับเปิด UI คืนมา (ซ่อนไว้ตอนแรก)
    local OpenGuiBtn = Instance.new("TextButton")
    OpenGuiBtn.Parent = ScreenGui
    OpenGuiBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    OpenGuiBtn.Position = UDim2.new(0, 20, 0, 20)
    OpenGuiBtn.Size = UDim2.new(0, 50, 0, 50)
    OpenGuiBtn.Text = "UI"
    OpenGuiBtn.TextColor3 = Color3.fromRGB(115, 196, 237)
    OpenGuiBtn.Font = Enum.Font.GothamBold
    OpenGuiBtn.TextSize = 18
    OpenGuiBtn.Visible = false
    Instance.new("UICorner", OpenGuiBtn).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", OpenGuiBtn).Thickness = 2

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.BackgroundColor3 = Color3.fromRGB(76, 76, 76)
    MainFrame.BackgroundTransparency = 0.1
    MainFrame.Position = UDim2.new(0.5, -250, 0.5, -175)
    MainFrame.Size = UDim2.new(0, 500, 0, 350)
    MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    local MainStroke = Instance.new("UIStroke", MainFrame)
    MainStroke.Thickness = 2

    -- แถบจับสำหรับลาก (TopBar) ที่ชัดเจน
    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Parent = MainFrame
    TopBar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    TopBar.Size = UDim2.new(1, 0, 0, 30)
    Instance.new("UICorner", TopBar)
    
    -- ลบมุมล่างของ TopBar ให้เนียนกับ MainFrame
    local TopBarFix = Instance.new("Frame")
    TopBarFix.Parent = TopBar
    TopBarFix.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    TopBarFix.Position = UDim2.new(0, 0, 0.5, 0)
    TopBarFix.Size = UDim2.new(1, 0, 0.5, 0)
    TopBarFix.BorderSizePixel = 0

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = TopBar
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Position = UDim2.new(0, 15, 0, 0)
    TitleLabel.Size = UDim2.new(0.8, 0, 1, 0)
    TitleLabel.Text = WindowName or "LMG2L Library"
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- ปุ่มปิด UI
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Parent = TopBar
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.Position = UDim2.new(1, -30, 0, 0)
    CloseBtn.Size = UDim2.new(0, 30, 1, 0)
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.TextSize = 16

    -- ระบบเปิด-ปิด UI
    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        OpenGuiBtn.Visible = true
    end)
    OpenGuiBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = true
        OpenGuiBtn.Visible = false
    end)

    -- ระบบลากหน้าต่าง (ผูกกับ TopBar)
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)

    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Parent = MainFrame
    Sidebar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    Sidebar.BackgroundTransparency = 0.5
    Sidebar.Position = UDim2.new(0.02, 0, 0.12, 0)
    Sidebar.Size = UDim2.new(0.25, 0, 0.84, 0)
    Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar)
    Instance.new("UIStroke", Sidebar)

    local SidebarList = Instance.new("UIListLayout", Sidebar)
    SidebarList.SortOrder = Enum.SortOrder.LayoutOrder
    SidebarList.Padding = UDim.new(0, 5)
    SidebarList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    local SidebarPadding = Instance.new("UIPadding", Sidebar)
    SidebarPadding.PaddingTop = UDim.new(0, 10)

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Name = "ContentContainer"
    ContentContainer.Parent = MainFrame
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Position = UDim2.new(0.29, 0, 0.12, 0)
    ContentContainer.Size = UDim2.new(0.69, 0, 0.84, 0)

    function WindowElements:CreateCategory(CategoryName)
        local CategoryElements = {}

        local CategoryBtn = Instance.new("TextButton")
        CategoryBtn.Parent = Sidebar
        CategoryBtn.BackgroundColor3 = Color3.fromRGB(73, 73, 73)
        CategoryBtn.Size = UDim2.new(0.9, 0, 0, 30)
        CategoryBtn.Font = Enum.Font.GothamBold
        CategoryBtn.Text = CategoryName
        CategoryBtn.TextColor3 = Color3.fromRGB(115, 196, 237)
        CategoryBtn.TextSize = 14
        Instance.new("UICorner", CategoryBtn)

        local CategoryPage = Instance.new("ScrollingFrame")
        CategoryPage.Parent = ContentContainer
        CategoryPage.BackgroundTransparency = 1
        CategoryPage.Size = UDim2.new(1, 0, 1, 0)
        CategoryPage.ScrollBarThickness = 4
        CategoryPage.Visible = false
        
        local PageLayout = Instance.new("UIListLayout", CategoryPage)
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 5)
        PageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

        local PagePadding = Instance.new("UIPadding", CategoryPage)
        PagePadding.PaddingTop = UDim.new(0, 5)

        local function SelectTab()
            for _, page in pairs(ContentContainer:GetChildren()) do
                if page:IsA("ScrollingFrame") then page.Visible = false end
            end
            for _, btn in pairs(Sidebar:GetChildren()) do
                if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(73, 73, 73) end
            end
            CategoryPage.Visible = true
            TweenService:Create(CategoryBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(90, 90, 90)}):Play()
        end

        CategoryBtn.MouseButton1Click:Connect(SelectTab)

        -- ทำให้หมวดหมู่แรกแสดงผลอัตโนมัติ
        if isFirstTab then
            SelectTab()
            isFirstTab = false
        end

        -- ฟังก์ชันเพิ่มข้อความ (Label)
        function CategoryElements:CreateLabel(Text)
            local LabelContainer = Instance.new("Frame")
            LabelContainer.Parent = CategoryPage
            LabelContainer.BackgroundTransparency = 1
            LabelContainer.Size = UDim2.new(0.95, 0, 0, 25)

            local LabelText = Instance.new("TextLabel")
            LabelText.Parent = LabelContainer
            LabelText.BackgroundTransparency = 1
            LabelText.Size = UDim2.new(1, 0, 1, 0)
            LabelText.Font = Enum.Font.GothamBold
            LabelText.Text = Text
            LabelText.TextColor3 = Color3.fromRGB(200, 200, 200)
            LabelText.TextSize = 14
            LabelText.TextXAlignment = Enum.TextXAlignment.Left
        end

        function CategoryElements:CreateButton(ButtonText, Callback)
            local ActionBtn = Instance.new("TextButton")
            ActionBtn.Parent = CategoryPage
            ActionBtn.BackgroundColor3 = Color3.fromRGB(73, 73, 73)
            ActionBtn.Size = UDim2.new(0.95, 0, 0, 35)
            ActionBtn.Font = Enum.Font.Gotham
            ActionBtn.Text = ButtonText
            ActionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            ActionBtn.TextSize = 14
            Instance.new("UICorner", ActionBtn)

            ActionBtn.MouseButton1Click:Connect(function()
                TweenService:Create(ActionBtn, TweenInfo.new(0.1), {Size = UDim2.new(0.9, 0, 0, 33)}):Play()
                task.wait(0.1)
                TweenService:Create(ActionBtn, TweenInfo.new(0.1), {Size = UDim2.new(0.95, 0, 0, 35)}):Play()
                if Callback then Callback() end
            end)
        end

        function CategoryElements:CreateToggle(ToggleText, DefaultState, Callback)
            local CurrentState = DefaultState or false
            local ToggleContainer = Instance.new("TextButton")
            ToggleContainer.Parent = CategoryPage
            ToggleContainer.BackgroundColor3 = Color3.fromRGB(73, 73, 73)
            ToggleContainer.Size = UDim2.new(0.95, 0, 0, 35)
            ToggleContainer.Text = ""
            ToggleContainer.AutoButtonColor = false
            Instance.new("UICorner", ToggleContainer)

            local ToggleLabel = Instance.new("TextLabel")
            ToggleLabel.Parent = ToggleContainer
            ToggleLabel.BackgroundTransparency = 1
            ToggleLabel.Position = UDim2.new(0, 10, 0, 0)
            ToggleLabel.Size = UDim2.new(0.7, 0, 1, 0)
            ToggleLabel.Font = Enum.Font.Gotham
            ToggleLabel.Text = ToggleText
            ToggleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            ToggleLabel.TextSize = 14
            ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left

            local ToggleBg = Instance.new("Frame")
            ToggleBg.Parent = ToggleContainer
            ToggleBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            ToggleBg.Position = UDim2.new(1, -45, 0.5, -10)
            ToggleBg.Size = UDim2.new(0, 35, 0, 20)
            Instance.new("UICorner", ToggleBg).CornerRadius = UDim.new(1, 0)

            local ToggleKnob = Instance.new("Frame")
            ToggleKnob.Parent = ToggleBg
            ToggleKnob.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
            ToggleKnob.Position = UDim2.new(0, 2, 0.5, -8)
            ToggleKnob.Size = UDim2.new(0, 16, 0, 16)
            Instance.new("UICorner", ToggleKnob).CornerRadius = UDim.new(1, 0)

            local function UpdateToggle(animate)
                local goalPos = CurrentState and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                local goalColor = CurrentState and Color3.fromRGB(115, 196, 237) or Color3.fromRGB(200, 200, 200)
                if animate then
                    TweenService:Create(ToggleKnob, TweenInfo.new(0.2), {Position = goalPos, BackgroundColor3 = goalColor}):Play()
                else
                    ToggleKnob.Position = goalPos
                    ToggleKnob.BackgroundColor3 = goalColor
                end
                if Callback then Callback(CurrentState) end
            end

            ToggleContainer.MouseButton1Click:Connect(function()
                CurrentState = not CurrentState
                UpdateToggle(true)
            end)
            UpdateToggle(false)
        end

        function CategoryElements:CreateSlider(SliderText, Min, Max, Default, Callback)
            local CurrentValue = Default or Min
            local SliderContainer = Instance.new("Frame")
            SliderContainer.Parent = CategoryPage
            SliderContainer.BackgroundColor3 = Color3.fromRGB(73, 73, 73)
            SliderContainer.Size = UDim2.new(0.95, 0, 0, 50)
            Instance.new("UICorner", SliderContainer)

            local SliderLabel = Instance.new("TextLabel")
            SliderLabel.Parent = SliderContainer
            SliderLabel.BackgroundTransparency = 1
            SliderLabel.Position = UDim2.new(0, 10, 0, 5)
            SliderLabel.Size = UDim2.new(0.5, 0, 0, 20)
            SliderLabel.Font = Enum.Font.Gotham
            SliderLabel.Text = SliderText
            SliderLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            SliderLabel.TextSize = 14
            SliderLabel.TextXAlignment = Enum.TextXAlignment.Left

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Parent = SliderContainer
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Position = UDim2.new(1, -60, 0, 5)
            ValueLabel.Size = UDim2.new(0, 50, 0, 20)
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.Text = tostring(CurrentValue)
            ValueLabel.TextColor3 = Color3.fromRGB(115, 196, 237)
            ValueLabel.TextSize = 14
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

            local SliderBg = Instance.new("TextButton")
            SliderBg.Parent = SliderContainer
            SliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            SliderBg.Position = UDim2.new(0, 10, 1, -15)
            SliderBg.Size = UDim2.new(1, -20, 0, 6)
            SliderBg.Text = ""
            SliderBg.AutoButtonColor = false
            Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(1, 0)

            local SliderFill = Instance.new("Frame")
            SliderFill.Parent = SliderBg
            SliderFill.BackgroundColor3 = Color3.fromRGB(115, 196, 237)
            SliderFill.Size = UDim2.new(math.clamp((CurrentValue - Min) / (Max - Min), 0, 1), 0, 1, 0)
            Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)

            local dragging = false
            local function UpdateSlider(input)
                local relativeX = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                CurrentValue = math.floor(Min + ((Max - Min) * relativeX))
                ValueLabel.Text = tostring(CurrentValue)
                TweenService:Create(SliderFill, TweenInfo.new(0.1), {Size = UDim2.new(relativeX, 0, 1, 0)}):Play()
                if Callback then Callback(CurrentValue) end
            end

            SliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    UpdateSlider(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)
        end

        -- ฟังก์ชันสร้าง Dropdown
        function CategoryElements:CreateDropdown(DropdownText, Options, Callback)
            local isOpen = false
            local DropdownContainer = Instance.new("Frame")
            DropdownContainer.Parent = CategoryPage
            DropdownContainer.BackgroundColor3 = Color3.fromRGB(73, 73, 73)
            DropdownContainer.Size = UDim2.new(0.95, 0, 0, 35)
            DropdownContainer.ClipsDescendants = true
            Instance.new("UICorner", DropdownContainer)

            local DropdownBtn = Instance.new("TextButton")
            DropdownBtn.Parent = DropdownContainer
            DropdownBtn.BackgroundTransparency = 1
            DropdownBtn.Size = UDim2.new(1, 0, 0, 35)
            DropdownBtn.Font = Enum.Font.Gotham
            DropdownBtn.Text = "  " .. DropdownText .. " : เลือกไอเทม"
            DropdownBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            DropdownBtn.TextSize = 14
            DropdownBtn.TextXAlignment = Enum.TextXAlignment.Left

            local ArrowLabel = Instance.new("TextLabel")
            ArrowLabel.Parent = DropdownBtn
            ArrowLabel.BackgroundTransparency = 1
            ArrowLabel.Position = UDim2.new(1, -30, 0, 0)
            ArrowLabel.Size = UDim2.new(0, 30, 1, 0)
            ArrowLabel.Font = Enum.Font.GothamBold
            ArrowLabel.Text = "+"
            ArrowLabel.TextColor3 = Color3.fromRGB(115, 196, 237)
            ArrowLabel.TextSize = 18

            local OptionList = Instance.new("Frame")
            OptionList.Parent = DropdownContainer
            OptionList.BackgroundTransparency = 1
            OptionList.Position = UDim2.new(0, 0, 0, 35)
            OptionList.Size = UDim2.new(1, 0, 1, -35)

            local ListLayout = Instance.new("UIListLayout", OptionList)
            ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local function UpdateSize()
                local targetHeight = isOpen and (35 + (#Options * 30)) or 35
                TweenService:Create(DropdownContainer, TweenInfo.new(0.2), {Size = UDim2.new(0.95, 0, 0, targetHeight)}):Play()
                ArrowLabel.Text = isOpen and "-" or "+"
            end

            DropdownBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                UpdateSize()
            end)

            for _, option in ipairs(Options) do
                local OptionBtn = Instance.new("TextButton")
                OptionBtn.Parent = OptionList
                OptionBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                OptionBtn.Size = UDim2.new(1, 0, 0, 30)
                OptionBtn.Font = Enum.Font.Gotham
                OptionBtn.Text = option
                OptionBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                OptionBtn.TextSize = 14
                
                OptionBtn.MouseButton1Click:Connect(function()
                    DropdownBtn.Text = "  " .. DropdownText .. " : " .. option
                    isOpen = false
                    UpdateSize()
                    if Callback then Callback(option) end
                end)
            end
        end

        return CategoryElements
    end

    return WindowElements
end

return Library
